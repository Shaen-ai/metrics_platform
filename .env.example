# Copy to .env.development / .env.production locally. Uses Next.js NEXT_PUBLIC_* (inlined at build).

# Laravel API used by admin (signup, catalog, Stripe, …). Example local: http://localhost:8000/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Marketing site origin (no trailing slash). Login/signup logo links here.
# Local: landing `npm run dev` → http://localhost:3002. Production defaults to https://tunzone.com if unset.
NEXT_PUBLIC_LANDING_URL=

# Marketing /pricing on the landing site (no trailing slash on origin; include path if needed).
# Local: landing dev often http://localhost:3002/pricing
NEXT_PUBLIC_PRICING_URL=http://localhost:3002/pricing

# Stripe Customer Portal (or similar) when wired after backend webhooks sync plan_tier.
NEXT_PUBLIC_BILLING_PORTAL_URL=

# Shown on Settings for subscription billing questions mailto:. Defaults to support@tunzone.com if unset.
NEXT_PUBLIC_SUBSCRIPTION_SUPPORT_EMAIL=support@tunzone.com
